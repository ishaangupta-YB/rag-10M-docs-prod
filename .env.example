# --- Model endpoints (local-first via vLLM; also works with Ollama and Cloudflare AI Gateway) ---
# For Ollama set RAG_LLM_BASE_URL=http://localhost:11434/v1
# For Cloudflare AI Gateway set RAG_LLM_BASE_URL=https://gateway.ai.cloudflare.com/v1/{account}/{gateway}/openai
RAG_LLM_BASE_URL=http://vllm:8000/v1
RAG_LLM_MODEL=Qwen3-32B
RAG_LLM_API_KEY=
RAG_LLM_TIMEOUT=120
RAG_LLM_MAX_RETRIES=3
RAG_LLM_MAX_TOKENS=1024

RAG_EMBEDDER_BASE_URL=http://vllm:8000/v1
RAG_EMBEDDER_MODEL=BAAI/bge-large-en-v1.5
RAG_EMBEDDER_DIM=1024
RAG_EMBEDDER_MAX_RETRIES=3
RAG_EMBEDDER_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:

RAG_RERANKER_BASE_URL=http://vllm:8000/v1
RAG_RERANKER_MODEL=Qwen3-32B

# Optional: leave blank to fall back to LLM judge
RAG_VERIFIER_BASE_URL=
RAG_VERIFIER_MODEL=

# --- Pipeline knobs ---
RAG_CHUNK_TOKENS=256
RAG_CHUNK_OVERLAP=32
RAG_RETRIEVE_K=20
RAG_RERANK_TOP_N=20
RAG_FUSION_KK=60
RAG_RRF_K=60
RAG_MAX_HOPS=3
RAG_CRAG_OK=0.7
RAG_CRAG_BAD=0.4
RAG_TAU_CLAIM=0.7
RAG_TAU_ABSTAIN=0.5
RAG_SEED=42

# --- Paths ---
RAG_ARTIFACT_DIR=./artifacts
RAG_DATA_DIR=./data
RAG_CHECKPOINT_DIR=./checkpoints
RAG_LANCEDB_URI=./artifacts/lancedb
RAG_BM25_PATH=./artifacts/bm25s

# --- Serving ---
RAG_HOST=0.0.0.0
RAG_PORT=8000
RAG_WORKERS=1
RAG_LOG_LEVEL=INFO

# --- Observability ---
RAG_OTEL_ENDPOINT=
RAG_METRICS_PORT=9090
RAG_ENABLE_TRACING=false

# --- Optional memory layer (mem0) ---
# Set ENABLE_MEMORY=true and add MEM0_API_KEY to activate.
RAG_ENABLE_MEMORY=false
RAG_MEM0_API_KEY=
RAG_MEM0_BASE_URL=
RAG_MEM0_USER_ID=default-user
RAG_MEMORY_TOP_K=3
